import feedparser
import os
import time
from datetime import datetime

# הגדרות
RSS_URL = "https://www.idf.il/RSS" # כתובת ה-RSS של דובר צה"ל
NEWS_DIR = "content/news"

if not os.path.exists(NEWS_DIR):
    os.makedirs(NEWS_DIR)

def create_news_file(title, content, image_url, video_url):
    timestamp = datetime.now().strftime("%Y-%m-%d-%H-%M-%S")
    filename = f"{NEWS_DIR}/{timestamp}.md"
    
    # בניית גוף המבזק כולל נגן וידאו אם קיים
    body = content
    if video_url:
        body += f'\n\n<video width="100%" controls><source src="{video_url}" type="video/mp4">הדפדפן שלך לא תומך בנגן וידאו.</video>'
    
    with open(filename, "w", encoding="utf-8") as f:
        f.write(f"---\n")
        f.write(f"title: \"{title}\"\n")
        f.write(f"date: \"{datetime.now().isoformat()}\"\n")
        f.write(f"category: \"ביטחון\"\n") # הקטגוריה שבחרת
        f.write(f"image: \"{image_url}\"\n")
        f.write(f"---\n\n")
        f.write(body)

# כאן הסקריפט ימשוך את הנתונים (דוגמה פשוטה)
feed = feedparser.parse(RSS_URL)
for entry in feed.entries[:3]: # לוקח את 3 המבזקים האחרונים
    # בדיקה אם המבזק כבר קיים (לפי כותרת) כדי למנוע כפילויות
    create_news_file(entry.title, entry.summary, "", "")
